<%= page_title "Templates" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-h2 text-neutral-900">All Templates</h1>
    <p class="text-body text-neutral-700 mt-1">Manage screen templates</p>
  </div>
  <div class="flex space-x-3">
    <% if policy(::Template.new).new? %>
      <%= link_to new_template_path, class: "btn-primary btn-md whitespace-nowrap" do %>
        <%= heroicon('plus', class: 'w-4 h-4 mr-2') %>
        New Template
      <% end %>
    <% end %>
  </div>
</div>

<div id="templates" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
  <% @templates.each do |template| %>
    <%= link_to template, class: "group block" do %>
      <div class="card hover:shadow-md transition-shadow duration-200">
        <div class="card-body">
          <div class="aspect-video bg-neutral-100 rounded overflow-hidden flex items-center justify-center mb-3">
            <% if template.image.attached? %>
              <%= image_tag template.image, class: "max-w-full max-h-full w-auto h-auto object-contain" %>
            <% else %>
              <span class="text-caption text-neutral-500 italic">No image</span>
            <% end %>
          </div>
          <h3 class="text-h4 text-neutral-900 group-hover:text-brand transition-colors text-center">
            <%= template.name %>
          </h3>
        </div>
      </div>
    <% end %>
  <% end %>
</div>