<%= page_title "Search" %>

<div class="mb-6">
  <h1 class="text-h2 text-neutral-900">Search</h1>
  <% if @query.present? %>
    <p class="text-body text-neutral-700 mt-1">
      <%= pluralize(@results.size, "result") %> for "<%= @query %>"
    </p>
  <% else %>
    <p class="text-body text-neutral-700 mt-1">Enter a search term to find content and feeds.</p>
  <% end %>
</div>

<%= form_with url: search_path, method: :get, local: true, class: "mb-6" do |f| %>
  <div class="relative max-w-2xl">
    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
      <svg class="h-5 w-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </div>
    <%= f.search_field :q, value: @query, placeholder: "Search content and feeds…", autofocus: true, class: "frm-input pl-10 w-full" %>
  </div>
<% end %>

<% if @query.present? && @results.any? %>
  <div class="space-y-3">
    <% @results.each do |record| %>
      <%= link_to polymorphic_path(record), class: "block card hover:shadow-md transition-shadow duration-200" do %>
        <div class="card-body">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <%= search_type_badge(record) %>
              </div>
              <h3 class="text-h3 text-neutral-900 truncate">
                <%= record.name.presence || "(untitled)" %>
              </h3>
              <% snippet = record.searchable_data[:body].to_s.truncate(160) %>
              <% if snippet.present? %>
                <p class="text-body text-neutral-700 mt-1 truncate">
                  <%= snippet %>
                </p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% elsif @query.present? %>
  <div class="text-center py-12">
    <svg class="mx-auto h-12 w-12 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    <h3 class="text-h3 text-neutral-900 mt-4">No matches</h3>
    <p class="text-body text-neutral-500 mt-2">No content or feeds matched "<%= @query %>".</p>
  </div>
<% end %>
